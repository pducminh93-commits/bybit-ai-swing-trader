# Database Configuration
DATABASE_URL=sqlite+aiosqlite:///./bybit_trader.db
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_PRE_PING=true

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true
API_WORKERS=1
API_DEBUG=false

# Security Configuration
SECURITY_SECRET_KEY=your-secret-key-change-in-production
SECURITY_ALGORITHM=HS256
SECURITY_ACCESS_TOKEN_EXPIRE_MINUTES=30
SECURITY_RATE_LIMIT_REQUESTS_PER_MINUTE=60
SECURITY_CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000"]

# ML Configuration
ML_DEFAULT_MODEL_TYPE=rf
ML_UNIVERSAL_MODEL_NAME=universal_ensemble_model
ML_TRAINING_TIMEOUT_SECONDS=300
ML_MAX_TRAINING_SAMPLES=10000
ML_VALIDATION_SPLIT=0.2

# Trading Configuration
TRADING_DEFAULT_CAPITAL=1000.0
TRADING_DEFAULT_LEVERAGE=10.0
TRADING_DEFAULT_STOP_LOSS_PCT=0.05
TRADING_DEFAULT_MIN_HOLD_CANDLES=6
TRADING_MAX_LEVERAGE=100.0
TRADING_MIN_CAPITAL=10.0
TRADING_MAX_CAPITAL=1000000.0

# Logging Configuration
LOGGING_LEVEL=INFO
LOGGING_FORMAT="%(asctime)s - %(name)s - %(levelname)s - %(message)s"
LOGGING_FILE_PATH=logs/bybit_trader.log
LOGGING_MAX_FILE_SIZE=10485760
LOGGING_BACKUP_COUNT=5

# Bybit API Configuration
BYBIT_API_KEY=your_api_key_here
BYBIT_API_SECRET=your_api_secret_here
BYBIT_TESTNET=true
BYBIT_BASE_URL=https://api.bybit.com
BYBIT_TESTNET_URL=https://api-testnet.bybit.com
BYBIT_TIMEOUT=30
BYBIT_RETRY_ATTEMPTS=3
BYBIT_RETRY_DELAY=1.0